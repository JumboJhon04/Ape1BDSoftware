            });
        }

        function handleAnswer(selectedIndex, btnElement) {
            if (isAnswered) return;
            isAnswered = true;

            const q = quizData[currentQIndex];
            const allBtns = elOptionsGrid.children;

            // Disable all
            for (let b of allBtns) b.classList.add('disabled');

            if (selectedIndex === q.correct) {
                btnElement.classList.add('correct');
                score += 100; // 100 points per hard question
                elScore.innerText = score;
            } else {
                btnElement.classList.add('wrong');
                // Reveal correct
                allBtns[q.correct].classList.remove('disabled');
                allBtns[q.correct].classList.add('correct');
            }

            // Show Explanation
            elExplanationText.innerText = q.explanation;
            elExplanationBox.style.display = 'block';

            // Show Next Button
            elNextBtn.style.display = 'block';
            if (currentQIndex === quizData.length - 1) {
                elNextBtn.innerHTML = `Analizar Desempeño Final <i class="fa-solid fa-flag-checkered" style="margin-left: 8px;"></i>`;
            }
        }

        elNextBtn.onclick = () => {
            currentQIndex++;
            if (currentQIndex < quizData.length) {
                loadQuestion();
            } else {
                showResults();
            }
        };

        function showResults() {
            elQuizInterface.style.display = 'none';
            elResultsInterface.style.display = 'flex';

            const points = score / 100;
            const percentage = (points / quizData.length) * 100;

            document.getElementById('final-score-text').innerText = `${points}/${quizData.length}`;
            document.getElementById('score-circle').style.setProperty('--progress', `${percentage}%`);

            const msg = document.getElementById('result-message');
            if (points === 6) {
                msg.innerText = "¡HACKER DETECTADO! Un puntaje perfecto en dificultad máxima. Eres un arquitecto de bases de datos de élite.";
                msg.style.color = "var(--primary)";
            } else if (points >= 4) {
                msg.innerText = "Nivel Senior comprobado. Sobreviviste a preguntas técnicas diseñadas para confundir a desarrolladores experimentados.";
                msg.style.color = "var(--success)";
            } else {
                msg.innerText = "Evaluación brutal. Has caído en las trampas técnicas de la sintaxis SQL. Revisa a fondo el análisis forense de cada pregunta.";
                msg.style.color = "#ef4444";
            }
        }

        function resetQuiz() {
            currentQIndex = 0;
            score = 0;
            elScore.innerText = score;
            elQuizInterface.style.display = 'block';
            elResultsInterface.style.display = 'none';
            document.getElementById('score-circle').style.setProperty('--progress', `0%`);
            loadQuestion();
        }

        // INIT
        updatePresentation();
        loadQuestion();

    </script>
</body>

</html>
